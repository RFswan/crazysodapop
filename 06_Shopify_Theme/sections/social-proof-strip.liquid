{{ 'crazy-soda-pop.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="csp-section csp-social-proof{% if section.settings.light_background %} csp-section--cream csp-social-proof--light{% else %} csp-section--navy{% endif %} section-{{ section.id }}-padding"
  aria-label="{{ section.settings.accessibility_label | escape }}"
>
  <div class="page-width">
    <ul class="csp-social-proof__list" role="list">
      {%- for block in section.blocks -%}
        <li class="csp-social-proof__item" {{ block.shopify_attributes }}>
          {{ block.settings.text | escape }}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "CSP Social proof strip",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "Store highlights"
    },
    {
      "type": "checkbox",
      "id": "light_background",
      "label": "Use cream background",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "statement",
      "name": "Statement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "100,000+ Orders Shipped"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CSP Social proof strip",
      "blocks": [
        { "type": "statement", "settings": { "text": "100,000+ Orders Shipped" } },
        { "type": "statement", "settings": { "text": "Free Shipping Over $39" } },
        { "type": "statement", "settings": { "text": "Free Shipping on Every Subscription" } }
      ]
    }
  ]
}
{% endschema %}
