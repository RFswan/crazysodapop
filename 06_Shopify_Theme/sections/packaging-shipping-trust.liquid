{{ 'crazy-soda-pop.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="csp-section csp-section--cream csp-trust section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="h1 center">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <div class="rte center" style="max-width: 60rem; margin: 0 auto 2rem;">{{ section.settings.intro }}</div>
    {%- endif -%}
    <div class="csp-trust__grid">
      {%- for block in section.blocks -%}
        <div class="csp-trust__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div style="max-width: 4rem; margin: 0 auto 1rem;">
              {{
                block.settings.icon
                | image_url: width: 120
                | image_tag: loading: 'lazy', alt: '', widths: '60, 120'
              }}
            </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="h4">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p>{{ block.settings.text | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CSP Shipping trust",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Honest packaging. Clear shipping."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Plain corrugated boxes, bubble-wrapped glass bottles, and straightforward shipping in the continental U.S.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon (optional)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Plain shipping box" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Every glass bottle is individually bubble wrapped in a plain corrugated shipper."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CSP Shipping trust",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "title": "Plain shipping box",
            "text": "Functional corrugated packaging with bubble wrap—no fake branded club cartons."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Free shipping over $39",
            "text": "Merchandise orders of $39 or more ship free in the continental United States."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Club shipping included",
            "text": "Every Soda Discovery Club subscription includes free shipping in the continental U.S."
          }
        }
      ]
    }
  ]
}
{% endschema %}
